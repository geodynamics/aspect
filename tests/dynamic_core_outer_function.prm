# Test dynamic core combined with the function boundary temperature model.
# The dynamic core model contributes only to the CMB, while the function
# model contributes only to the outer boundary.

include @SOURCE_DIR@/dynamic_core.prm

set End time          = 0

subsection Material model
  subsection Simple compressible model
    set Thermal expansion coefficient = 1e-6
    set Viscosity                     = 1e25
  end
end

subsection Geometry model
  subsection Spherical shell
    set Opening angle = 90
  end
end

subsection Boundary temperature model
  set Fixed temperature boundary indicators = inner, outer
  set List of model names = dynamic core, function

  subsection Dynamic core
    set Outer temperature = 0
  end

  subsection Function
    set Coordinate system   = spherical
    set Variable names      = r,phi,t
    set Function expression = if(r > 5000000, 100 + 200*sin(phi) + 0*t, 0)
    set Minimal temperature = 0
    set Maximal temperature = 300
  end
end

subsection Mesh refinement
  set Initial global refinement          = 1
  set Initial adaptive refinement        = 0
  set Time steps between mesh refinement = 0
end

subsection Postprocess
  set List of postprocessors = core statistics, temperature statistics

  subsection Dynamic core statistics
    set Excess entropy only = true
  end
end

subsection Termination criteria
  set Termination criteria = end time
end
