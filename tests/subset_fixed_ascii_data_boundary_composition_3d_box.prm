##### simple test for ascii data composition
##### where different fields are fixed on 
##### different boundaries with two different plugins.

set Dimension                              = 3
set Use years instead of seconds           = true
set End time                               = 0
set Adiabatic surface temperature          = 1613.0

subsection Geometry model
  set Model name = box

  subsection Box
    set X extent = 660000
    set Y extent = 660000
    set Z extent = 660000
  end
end

subsection Initial composition model
  subsection Function
    set Function expression = 1; 1; 1
  end
end

subsection Initial temperature model
  set Model name = adiabatic

  subsection Adiabatic
    set Amplitude = 300
    set Radius    = 250000
    subsection Function
      set Function expression = 1; 1; 1
    end
  end
end

subsection Compositional fields
  set Number of fields = 3
  set Names of fields = field0, field1, field2
end

subsection Boundary composition model
  # Spaces are okay to include
  set Fixed composition boundary indicators   = bottom[field0|field1]:ascii data,\
                                                bottom[field2]:function,\
                                                left[field0|field1]:ascii data, \
                                                left[field2]:function, \
                                                top[field0]:ascii data, \
                                                top[field1|field2] :function, \
                                                front [field1]:ascii data, \
                                                front[field0|field2]: function, \
                                                back[field0|field1] : ascii data, \
                                                back [field2] : function

  subsection Ascii data model
    set Data file name       = box_3d_2fields_%s.0.txt
  end
  subsection Function
    set Function expression = 10;20;30
  end
end

subsection Boundary temperature model
  set List of model names = box
  set Fixed temperature boundary indicators   = top,bottom
end

subsection Boundary velocity model
  set Prescribed velocity boundary indicators = bottom:function,left:function,right:function,top:function,front:function,back:function

  subsection Function
    set Function expression = 1;0;0
  end
end

subsection Gravity model
  set Model name = vertical

  subsection Vertical
    set Magnitude = 10
  end
end

subsection Material model
  set Model name = simple

  subsection Simple model
    set Viscosity = 1e21
  end
end

subsection Mesh refinement
  set Initial global refinement                = 1
  set Initial adaptive refinement              = 0
  set Time steps between mesh refinement       = 0
  set Strategy                                 = temperature
end

subsection Postprocess
  set List of postprocessors = velocity statistics, temperature statistics, heat flux statistics, composition statistics
end
