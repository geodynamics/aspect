# This test verifies the Isostacy mesh deformation plugin.
# It computes an initial isostatic surface deformation for a 2-D box
# containing a continental plate on the left and an oceanic plate on the
# right, and outputs the resulting topography for comparison.
set Dimension = 2
set Start time = 0
set End time = 0
set Use years instead of seconds = true
set CFL number = 0.5
set Pressure normalization = no
set Maximum time step = 1e5

subsection Solver parameters
    subsection Stokes solver parameters
        set Stokes solver type = block GMG
        set GMRES solver restart length = 100
        set Number of cheap Stokes solver steps = 200
        set Use full A block as preconditioner = true
        set Linear solver tolerance = 1.0e-04
        set Maximum number of expensive Stokes solver steps = 0
    end
end

subsection Geometry model
  set Model name = box
  subsection Box
    set X extent = 5500e3
    set Y extent = 1000e3
    set X repetitions = 11
    set Y repetitions = 2
  end

end

subsection Gravity model
  set Model name = vertical
  subsection Vertical
    set Magnitude = 9.81
  end
end

subsection Mesh deformation
  set Mesh deformation boundary indicators = top: isostacy
  set Additional tangential mesh velocity boundary indicators = left, right
  subsection Isostacy
    set Number of lateral points = 2000
    set Number of vertical points = 2000
    set Balanced depth = 500e3
    set Maximum isostatic topography = 10e3
  end
end

subsection Boundary velocity model
  set Tangential velocity boundary indicators = left, right, bottom
end

subsection Compositional fields
  set Number of fields = 2
  set Names of fields = continental_crust, oceanic_crust
end

subsection Initial composition model
  set Model name = function
  subsection Function
    set Variable names = x,y
    set Function constants = W=5500e3,H=1000e3,Dcc=35e3,Doc=7.5e3
    set Function expression = if(x<W/2 && y>H-Dcc,1,0); if(x>=W/2 && y>H-Doc,1,0)
  end
end

subsection Boundary composition model
  set List of model names = initial composition
end

subsection Initial temperature model
  set Model name = function
  subsection Function
    set Variable names = x,y
    set Function constants = W=5500e3,H=1000e3,Ts=273,Tm=1573,Lc=120e3,Lo=80e3
    set Function expression = if(x<W/2,Ts+(Tm-Ts)*min((H-y)/Lc,1),Ts+(Tm-Ts)*min((H-y)/Lo,1))
  end
end

subsection Boundary temperature model
  set Fixed temperature boundary indicators = top, bottom
  set List of model names = box
  subsection Box
    set Top temperature = 273
    set Bottom temperature = 1573
  end
end

subsection Material model
  set Model name = visco plastic
  set Material averaging = harmonic average only viscosity
  subsection Visco Plastic
    set Reference temperature = 1573
    set Minimum viscosity = 1e20
    set Maximum viscosity = 1e23
    set Minimum strain rate = 1e-20
    set Reference strain rate = 1e-15
    set Densities = background: 3300, continental_crust: 2800, oceanic_crust: 3000
    set Thermal expansivities = 3e-5
    set Heat capacities = 1250
    set Thermal diffusivities = 1e-6
    set Viscosity averaging scheme = harmonic
    set Viscous flow law = diffusion
    set Prefactors for diffusion creep = 5e-23
    set Activation energies for diffusion creep = 0
    set Activation volumes for diffusion creep = 0
    set Grain size exponents for diffusion creep = 0
    set Cohesions = 1e9
    set Angles of internal friction = 0
  end
end

subsection Mesh refinement
  set Initial global refinement = 3
  set Initial adaptive refinement = 0
  set Time steps between mesh refinement = 0
end


subsection Postprocess
  set List of postprocessors = basic statistics, composition statistics, temperature statistics, velocity statistics, visualization,  topography
  subsection Visualization
    set Output format = gnuplot
    set Time between graphical output = 1e5
    set Interpolate output = true
    set List of output variables = material properties
    subsection Material properties
      set List of material properties = density, viscosity
    end
  end
  subsection Topography
    set Output to file = true
    set Time between text output = 1e5
  end
end
