# Test that we can create additional checkpoints at specified times, and that we can still resume
# from the regular checkpoint determined by the checkpoint step frequency.

##################################################################
include $ASPECT_SOURCE_DIR/tests/diffusion.prm

set Dimension = 2

set End time                               = 8e7

set Resume computation                     = false

set Start time                             = 0


subsection Checkpointing
  set Time between checkpoint                = 0
  set Steps between checkpoint               = 6
  set Additional checkpoint times            = 1.5e7, 2.7e7
  set Resume time                            = 7.8e7
end
