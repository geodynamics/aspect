# This test is the same as fastscape_kf_function.prm, except
# that the input parameter units are given in seconds instead of years.
# The output should be exactly the same.
# Enable if: ASPECT_WITH_FASTSCAPE
include $ASPECT_SOURCE_DIR/tests/fastscape_kf_function.prm

set Dimension                              = 2
set Use years instead of seconds           = false
set End time                               = 15778476000000
set Maximum time step                      = 631139040000
set Output directory                       = fastscape_kf_function_in_seconds

subsection Mesh deformation
  subsection Fastscape
  # The default max timestep size is 10 ky.
  set Maximum timestep length = 315569520000.
   
   subsection Erosional parameters
    set Use kf distribution function = true
    subsection kf distribution function
      set Variable names = x,y,t
      set Function constants = year_in_seconds=31556952. #60*60*24*365.2425
      set Function expression = if(t<=250e3*year_in_seconds, 1e-6/year_in_seconds, if(x>25e3,1e-4/year_in_seconds, 1e-6/year_in_seconds))
    end
     set Sediment river incision rate = 3.16887385e-13
     set Bedrock diffusivity = -1    
     set Sediment diffusivity = -1
   end
  end
end  

subsection Postprocess
  set List of postprocessors = visualization

  subsection Visualization
    set Time between graphical output = 15778476000000
    set Interpolate output = false
    set Output format =  gnuplot
  end
end
