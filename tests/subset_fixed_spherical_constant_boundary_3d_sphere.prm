# This test ensures that the spherical constant
# boundary composition sets the composition
# at the surface of a sphere

set Dimension                              = 2
set End time                               = 0

subsection Compositional fields
  set Number of fields          = 4
  set Names of fields = field0, field1, field2, field3
end

subsection Initial composition model
  set List of model names = function

  subsection Function
    set Function expression = 1;1;1;1
  end
end

subsection Boundary composition model
  set List of model names = spherical constant
  set Fixed composition boundary indicators   = top[field0|field3]:spherical constant

  subsection Spherical constant
    set Outer composition = 4,10
  end
end

subsection Geometry model
  set Model name = sphere
end

subsection Gravity model
  set Model name = radial constant

  subsection Radial constant
    set Magnitude = 9.81
  end
end

subsection Initial temperature model
  set Model name = function

  subsection Function
    set Function expression = 500
  end
end

subsection Material model
  set Model name         = simpler

  subsection Simpler model
    set Viscosity = 1e21
  end
end

subsection Mesh refinement
  set Initial adaptive refinement              = 0
  set Initial global refinement                = 2
end

subsection Boundary velocity model
  set Tangential velocity boundary indicators = 0
end

subsection Postprocess
  set List of postprocessors = visualization, composition statistics

  subsection Visualization
    set Interpolate output = false
    set List of output variables = depth
    set Output format = gnuplot
  end
end
