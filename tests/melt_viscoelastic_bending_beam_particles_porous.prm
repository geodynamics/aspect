# This test checks whether the viscoelastic bending beam benchmark
# run successfully with two-phase flow. In particular, this benchmark is a good test to
# ensure that a model using active particles to track both viscoelastic
# stresses and lithologies, which affect material properties, works.
# At porosity=0 it should yield identical results to viscoelastic_bending_beam.prm
# Here porosity=0.1, to check if melt presence crashes.
include $ASPECT_SOURCE_DIR/benchmarks/viscoelastic_bending_beam/viscoelastic_bending_beam.prm

# For particles, the stress update is done by the particle property elastic stress,
# so we do not use the operator splitting.
set Use operator splitting                 = false

set End time         = 5e2
set Output directory = melt_viscoelastic_bending_beam_particles
set Max nonlinear iterations               = 5

# Significantly reduce resolution
subsection Geometry model
  set Model name = box

  subsection Box
    set X repetitions = 5
    set Y repetitions = 5
  end
end

subsection Melt settings
  set Include melt transport = true
end

subsection Compositional fields
  set Number of fields = 9
  set Names of fields  = ve_stress_xx, ve_stress_yy, ve_stress_xy, ve_stress_xx_old, ve_stress_yy_old, ve_stress_xy_old, beam, porosity, bound_fluid
  set Types of fields  = stress, stress, stress, stress, stress, stress, chemical composition, chemical composition, chemical composition
  set Compositional field methods = particles, particles, particles, particles, particles, particles, particles, field, field
  set Mapped particle properties  = ve_stress_xx:ve_stress_xx, ve_stress_yy:ve_stress_yy, ve_stress_xy:ve_stress_xy, ve_stress_xx_old:ve_stress_xx_old, ve_stress_yy_old:ve_stress_yy_old, ve_stress_xy_old:ve_stress_xy_old, beam:initial beam
end

subsection Initial composition model
  subsection Function
    set Function expression = 0; 0; 0; 0; 0; 0; if (x<=4.5e3 && y>=2.5e3 && y<=3.0e3, 1, 0); 0.1; 0
  end
end

subsection Discretization
  set Use discontinuous composition discretization = true, true, true, true, true, true, false, false, false
  subsection Stabilization parameters
    set Use limiter for discontinuous composition solution = false, false, false, false, false, false, false, false, false
    set Global composition maximum =  1.e11,  1.e11,  1.e11,  1.e11,  1.e11,  1.e11, 1.0, 1.0, 1.0
    set Global composition minimum = -1.e11, -1.e11, -1.e11, -1.e11, -1.e11, -1.e11, 0.0, 0.0, 0.0
  end
end

subsection Material model
  set Model name = reactive fluid transport
  subsection Reactive Fluid Transport Model
    set Base model                  = viscoelastic
    set Reference fluid density     = 2800
    set Reference fluid viscosity   = 10
    set Reference permeability      = 1e-8
    set Fluid-solid reaction scheme = no reaction
  end
  subsection Viscoelastic
    set Densities            =  2800, 3300, 2800, 2800
    set Viscosities          = 1.e18, 1.e24, 1.e18, 1.e18
    set Elastic shear moduli = 1.e11, 1.e10, 1.e11, 1.e11
    set Fixed elastic time step     = 1e3
    set Use fixed elastic time step = false
    set Viscosity averaging scheme  = maximum composition
  end
end

subsection Particles
  set Minimum particles per cell  = 25
  set Maximum particles per cell  = 35
  set Load balancing strategy     = remove and add particles
  set List of particle properties = initial composition, elastic stress
  set Interpolation scheme        = linear least squares
  set Particle generator name     = random uniform

  subsection Generator 
    subsection Random uniform
      set Number of particles = 4.5e3
    end
  end
end

# Post processing
subsection Postprocess
  set List of postprocessors = velocity statistics, depth average

  subsection Depth average
    set Time between graphical output = 0
    set Number of zones = 5
    set List of output variables = composition
    set Output format = txt
  end
end
